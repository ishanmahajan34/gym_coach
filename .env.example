# --- Required for full functionality (milestones 4+) ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your personal Telegram chat ID — get by messaging the bot, then visiting
# https://api.telegram.org/bot<TOKEN>/getUpdates and finding "chat":{"id":...}
TELEGRAM_CHAT_ID=

# Get from aistudio.google.com (free tier)
GEMINI_API_KEY=

# --- Required from milestone 1 ---
# Random secret for signing session cookies and magic links.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_me_run_the_command_in_the_comment_above

# --- Optional, sensible defaults ---
TIMEZONE=America/Los_Angeles
DB_URL=sqlite+aiosqlite:///./data/coach.db

# When the bot pings you (24h, in your TIMEZONE)
MORNING_NUDGE_HOUR=7
MORNING_NUDGE_MINUTE=0
EVENING_CHECKIN_HOUR=21
EVENING_CHECKIN_MINUTE=0
SUNDAY_PLAN_HOUR=19
SUNDAY_PLAN_MINUTE=0

# Public URL of your webapp (for magic links). Localhost for dev.
PUBLIC_BASE_URL=http://localhost:8000

# Set to "true" to disable the Telegram bot (useful for local dev with no token)
DISABLE_BOT=true
DISABLE_SCHEDULER=true
